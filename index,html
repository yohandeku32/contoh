    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            window.addEventListener('scroll', function() {
                const nav = document.querySelector('.navbar');
                if (window.scrollY > 40) {
                    nav.classList.add('scrolled');
                } else {
                    nav.classList.remove('scrolled');
                }
            });

            const dropZone = document.getElementById("dropZone");
            const fileInput = document.getElementById("fileUpload");
            const fileInfo = document.getElementById("fileInfo");
            const fileNameDisplay = document.getElementById("fileName");
            
            ['dragenter', 'dragover'].forEach(name => {
                dropZone.addEventListener(name, (e) => { e.preventDefault(); dropZone.classList.add('dragover'); });
            });
            ['dragleave', 'drop'].forEach(name => {
                dropZone.addEventListener(name, (e) => { e.preventDefault(); dropZone.classList.remove('dragover'); });
            });

            dropZone.addEventListener('drop', (e) => {
                if(e.dataTransfer.files.length > 0) {
                    fileInput.files = e.dataTransfer.files;
                    updateFileInfo();
                }
            });

            fileInput.addEventListener('change', updateFileInfo);

            function updateFileInfo() {
                if (fileInput.files.length > 0) {
                    const file = fileInput.files[0];
                    const sizeMB = file.size / (1024 * 1024);
                    if (sizeMB > 20) {
                        showAlert('Ukuran file berkas terlalu besar, maksimal berkapasitas 20 MB.', 'danger');
                        fileInput.value = "";
                        fileInfo.style.display = "none";
                    } else {
                        fileNameDisplay.textContent = `${file.name} (${sizeMB.toFixed(2)} MB)`;
                        fileInfo.style.display = "block";
                    }
                } else {
                    fileInfo.style.display = "none";
                }
            }

            document.getElementById('btnReset').addEventListener('click', () => {
                fileInfo.style.display = "none";
                document.getElementById('alertPlaceholder').innerHTML = "";
                document.getElementById("uploadForm").classList.remove('was-validated');
            });

            const form = document.getElementById("uploadForm");
            const alertPlaceholder = document.getElementById("alertPlaceholder");
            const successModal = new bootstrap.Modal(document.getElementById('successModal'));

            function showAlert(msg, type) {
                alertPlaceholder.innerHTML = `
                    <div class="alert alert-${type} alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-radius:14px;">
                        <i class="bi bi-exclamation-circle-fill me-2"></i> ${msg}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>`;
                alertPlaceholder.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }

            form.addEventListener("submit", function(e) {
                e.preventDefault();
                if (!form.checkValidity()) {
                    showAlert("Semua field wajib diisi sebelum mengunggah dokumen pendukung.", "danger");
                } else {
                    alertPlaceholder.innerHTML = "";
                    successModal.show();
                    form.reset();
                    fileInfo.style.display = "none";
                    form.classList.remove('was-validated');
                }
                form.classList.add('was-validated');
            });
        });
    </script>
