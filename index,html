<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SILAKIP - Kabupaten Malaka</title>
    <link class="favicon" rel="icon" href="https://upload.wikimedia.org/wikipedia/commons/d/d4/Lambang_Kabupaten_Malaka.png" type="image/png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root {
            --primary: #0F766E;          /* Deep Teal */
            --primary-glow: rgba(15, 118, 110, 0.15);
            --secondary: #14B8A6;        /* Emerald */
            --accent: #F59E0B;           /* Warm Gold */
            --bg-light: #F8FAFC;         /* Soft Off-White */
            --dark-slate: #0F172A;       /* Midnight Dark */
            --text-muted: #64748B;
            --glass-bg: rgba(255, 255, 255, 0.75);
            --glass-border: rgba(226, 232, 240, 0.8);
            --radius-premium: 24px;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-light);
            color: var(--dark-slate);
            overflow-x: hidden;
            letter-spacing: -0.2px;
        }

        /* --- BACKGROUND ARTIFACTS (Mesh & Noise) --- */
        .mesh-gradient-bg {
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 950px;
            background: 
                radial-gradient(circle at 80% 20%, rgba(20, 184, 166, 0.15) 0%, transparent 40%),
                radial-gradient(circle at 15% 50%, rgba(15, 118, 110, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 50% 80%, rgba(245, 158, 11, 0.04) 0%, transparent 45%);
            z-index: -1;
            filter: blur(60px);
        }

        .noise-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            opacity: 0.02;
            pointer-events: none;
            z-index: -1;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }

        /* --- FLOATING NAVBAR --- */
        .navbar {
            width: 92%;
            max-width: 1400px;
            margin: 20px auto;
            left: 0; right: 0;
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 999px;
            padding: 12px 28px;
            box-shadow: 0 4px 30px rgba(15, 23, 42, 0.03);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        
        .navbar.scrolled {
            transform: translateY(-5px);
            width: 85%;
            padding: 10px 24px;
            box-shadow: 0 10px 40px rgba(15, 23, 42, 0.08);
            border-color: rgba(15, 118, 110, 0.15);
        }

        .navbar-brand {
            font-weight: 900;
            font-size: 1.5rem;
            letter-spacing: -1px;
            color: var(--dark-slate) !important;
        }

        .navbar-brand span {
            color: var(--primary);
            position: relative;
        }

        .navbar-brand img {
            width: 38px;
            height: auto;
            filter: drop-shadow(0 2px 8px rgba(15, 118, 110, 0.2));
        }

        .nav-link {
            font-weight: 600;
            color: #475569 !important;
            padding: 6px 16px !important;
            font-size: 0.95rem;
            position: relative;
            transition: color 0.3s ease;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0; left: 16px; right: 16px;
            height: 2px;
            background: var(--primary);
            transform: scaleX(0);
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .nav-link:hover::after {
            transform: scaleX(1);
        }

        .nav-link:hover {
            color: var(--dark-slate) !important;
        }

        /* --- REDESIGNED HERO SECTION (Asymmetric) --- */
        .hero-section {
            padding: 180px 0 100px;
            position: relative;
            overflow: visible;
        }

        .hero-badge {
            background: rgba(20, 184, 166, 0.08);
            border: 1px solid rgba(20, 184, 166, 0.2);
            color: var(--primary);
            padding: 6px 16px;
            border-radius: 99px;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 28px;
            animation: fadeInDown 0.6s ease;
        }

        .hero-badge::before {
            content: '';
            width: 6px; height: 6px;
            background: var(--secondary);
            border-radius: 50%;
            display: inline-block;
        }

        .hero-title {
            font-size: 3.8rem;
            font-weight: 900;
            letter-spacing: -2px;
            color: var(--dark-slate);
            line-height: 1.15;
            margin-bottom: 24px;
        }

        .hero-title span {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-title .hero-sub-text {
            font-size: 1.8rem;
            font-weight: 600;
            color: #475569;
            display: block;
            margin-top: 12px;
            letter-spacing: -0.5px;
        }

        .hero-subtitle {
            font-size: 1.15rem;
            font-weight: 400;
            color: #64748B;
            line-height: 1.6;
            margin-bottom: 40px;
            max-width: 580px;
        }

        /* --- PREMIUM BUTTON INTERACTIONS --- */
        .btn {
            padding: 14px 32px;
            border-radius: 14px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-pill { border-radius: 999px; }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, #0d635c 100%);
            border: none;
            box-shadow: 0 4px 20px var(--primary-glow);
            color: #ffffff;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 28px rgba(15, 118, 110, 0.3);
            background: linear-gradient(135deg, #0d635c 0%, var(--primary) 100%);
        }

        .btn-primary i {
            transition: transform 0.3s ease;
        }

        .btn-primary:hover i {
            transform: translateX(4px);
        }

        .btn-outline-secondary {
            border: 1px solid var(--glass-border);
            background: #ffffff;
            color: #334155;
        }

        .btn-outline-secondary:hover {
            background: #F1F5F9;
            border-color: #CBD5E1;
            color: var(--dark-slate);
            transform: translateY(-2px);
        }

        /* --- FLOATING PREMIUM DASHBOARD PREVIEW --- */
        .dashboard-window {
            background: rgba(255, 255, 255, 0.45);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 30px;
            padding: 30px;
            box-shadow: 0 30px 70px rgba(15, 23, 42, 0.08);
            position: relative;
            min-height: 440px;
            animation: floatAnimation 6s ease-in-out infinite;
        }

        /* Glassmorphism Floating Cards */
        .floating-pane {
            position: absolute;
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 15px 35px rgba(15, 23, 42, 0.04);
            transition: all 0.3s ease;
        }

        .floating-pane:hover {
            transform: scale(1.03) translateY(-5px);
            border-color: rgba(20, 184, 166, 0.3);
        }

        .pane-progress {
            top: -20px; left: -30px; width: 190px;
            animation: floatAnimation 5s ease-in-out infinite alternate;
        }

        .pane-activity {
            bottom: -25px; left: 20px; width: 280px;
            animation: floatAnimation 7s ease-in-out infinite alternate;
        }

        .pane-chart {
            top: 40px; right: -35px; width: 240px;
            animation: floatAnimation 5.5s ease-in-out infinite alternate-reverse;
        }

        /* Micro Components inside Dashboard Preview */
        .progress-ring-circle {
            stroke-dasharray: 251.2;
            stroke-dashoffset: 50.2; /* 80% progress */
            transform: rotate(-90deg);
            transform-origin: 50px 50px;
            transition: stroke-dashoffset 1s ease-out;
        }

        .mini-bar {
            height: 8px; background: #E2E8F0; border-radius: 4px; overflow: hidden;
        }
        .mini-bar-fill {
            height: 100%; background: var(--secondary); border-radius: 4px;
        }

        /* --- ASYMMETRIC STATS SECTION --- */
        .stats-section {
            padding: 40px 0 120px;
            position: relative;
            z-index: 5;
        }

        .stat-card-wrapper {
            display: grid;
            grid-template-columns: 1.2fr 1fr 1.3fr;
            gap: 24px;
        }

        .stat-premium-card {
            background: #ffffff;
            border: 1px solid var(--glass-border);
            padding: 40px 35px;
            border-radius: var(--radius-premium);
            box-shadow: 0 10px 40px rgba(15, 23, 42, 0.02);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* Intentional Asymmetric heights and styles */
        .stat-premium-card.large-stat {
            padding: 50px 40px;
            background: linear-gradient(135deg, var(--dark-slate) 0%, #1E293B 100%);
            color: #ffffff;
            border: none;
        }

        .stat-premium-card.mid-stat {
            transform: translateY(20px);
            border-bottom: 4px solid var(--accent);
        }

        .stat-premium-card.tall-stat {
            transform: translateY(-15px);
            background: linear-gradient(180deg, #ffffff 0%, #F8FAFC 100%);
        }

        .stat-premium-card:hover {
            transform: translateY(-8px) scale(1.01);
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.06);
        }

        .stat-number {
            font-size: 3.8rem;
            font-weight: 900;
            line-height: 1;
            letter-spacing: -2px;
            margin-bottom: 8px;
        }

        .large-stat .stat-number {
            background: linear-gradient(135deg, #ffffff 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* --- BENTO GRID FEATURES SECTION --- */
        .bento-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            grid-auto-rows: minmax(180px, auto);
            gap: 24px;
        }

        .bento-card {
            background: #ffffff;
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-premium);
            padding: 36px;
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            display: flex;
            flex-direction: column;
            justify-content: cubic-bezier;
        }

        .bento-card:hover {
            box-shadow: 0 30px 60px rgba(15, 23, 42, 0.06);
            border-color: rgba(15, 118, 110, 0.2);
            transform: translateY(-5px);
        }

        /* Bento Architecture variants */
        .bento-size-lg {
            grid-column: span 2;
            grid-row: span 2;
            background: radial-gradient(circle at 90% 10%, rgba(20, 184, 166, 0.04) 0%, transparent 40%), #ffffff;
        }

        .bento-size-md {
            grid-column: span 1;
            grid-row: span 2;
            background: linear-gradient(180deg, #ffffff 0%, #F1F5F9 100%);
        }

        .bento-icon-box {
            width: 56px; height: 56px;
            border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            font-size: 24px; color: #ffffff;
            margin-bottom: 28px;
            position: relative;
        }

        .bento-icon-box::after {
            content: ''; position: absolute;
            width: 100%; height: 100%;
            border-radius: 16px; top: 4px; left: 4px;
            opacity: 0.25; z-index: -1;
            background: inherit;
        }

        /* --- PREMIUM DROPZONE UPLOAD SECTION --- */
        .upload-section-wrapper {
            background: linear-gradient(180deg, transparent 0%, rgba(241, 245, 249, 0.6) 100%);
            padding: 100px 0;
        }

        .form-card {
            background: #ffffff;
            border-radius: 32px;
            border: 1px solid var(--glass-border);
            box-shadow: 0 40px 90px rgba(15, 23, 42, 0.04);
            padding: 50px;
            position: relative;
        }

        .form-card::before {
            content: ''; position: absolute;
            top: 0; left: 10%; right: 10%; height: 4px;
            background: linear-gradient(90deg, transparent 0%, var(--primary) 50%, transparent 100%);
        }

        .form-label {
            font-weight: 700;
            color: #334155;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 10px;
        }

        .form-control, .form-select {
            border-radius: 16px;
            padding: 16px 20px;
            border: 1px solid #E2E8F0;
            background-color: #F8FAFC;
            color: var(--dark-slate);
            font-size: 1rem;
            font-weight: 500;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .form-control:focus, .form-select:focus {
            background-color: #ffffff;
            border-color: var(--primary);
            box-shadow: 0 0 0 5px var(--primary-glow);
        }

        /* Google Drive/Dropbox Style Dynamic Dropzone */
        .drop-zone {
            border: 2px dashed #CBD5E1;
            border-radius: 24px;
            padding: 60px 30px;
            text-align: center;
            cursor: pointer;
            background-color: #F8FAFC;
            position: relative;
            transition: all 0.3s ease;
        }

        .drop-zone:hover, .drop-zone.dragover {
            border-color: var(--secondary);
            background-color: rgba(20, 184, 166, 0.02);
            transform: scale(0.995);
        }

        .drop-zone-icon-container {
            width: 80px; height: 80px;
            background: #ffffff;
            border-radius: 50%;
            display: inline-flex;
            align-items: center; justify-content: center;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.04);
            margin-bottom: 20px;
            color: var(--primary);
            font-size: 32px;
            transition: transform 0.3s ease;
        }

        .drop-zone:hover .drop-zone-icon-container {
            transform: translateY(-5px);
            color: var(--secondary);
        }

        /* --- PREMIUM MODERN FOOTER (SaaS Standard) --- */
        footer {
            background-color: var(--dark-slate);
            color: #F1F5F9;
            padding: 80px 0 35px;
            position: relative;
            overflow: hidden;
        }

        footer::before {
            content: ''; position: absolute;
            top: 0; left: 0; right: 0; height: 1px;
            background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0) 100%);
        }

        .footer-logo-area {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 14px 20px;
            border-radius: 16px;
            backdrop-filter: blur(10px);
            display: inline-flex;
            align-items: center;
            gap: 12px;
        }

        .footer-logo-area img {
            width: 26px; /* Optimized smaller corporate scale */
            height: auto;
            filter: grayscale(20%) brightness(110%);
        }

        .footer-office {
            color: #94A3B8;
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .footer-headline {
            font-weight: 700;
            font-size: 1.1rem;
            letter-spacing: -0.3px;
            color: #FFFFFF;
        }

        /* --- ANIMATIONS DEFINITIONS --- */
        @keyframes floatAnimation {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-12px); }
            100% { transform: translateY(0px); }
        }

        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* --- RESPONSIVE ADJUSTMENTS --- */
        @media (max-width: 1199px) {
            .hero-title { font-size: 3rem; }
            .stat-card-wrapper { grid-template-columns: 1fr; gap: 16px; }
            .stat-premium-card { transform: none !important; }
            .bento-container { grid-template-columns: 1fr; }
            .bento-size-lg { grid-column: span 1; grid-row: span 1; }
        }

        @media (max-width: 768px) {
            .navbar { width: 95%; padding: 10px 16px; }
            .hero-title { font-size: 2.3rem; .hero-sub-text { font-size: 1.3rem; } }
            .dashboard-window { display: none; }
            .form-card { padding: 24px; }
        }
    </style>
</head>
<body>

    <div class="mesh-gradient-bg"></div>
    <div class="noise-overlay"></div>

    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-3" href="#">
                <img src="https://upload.wikimedia.org/wikipedia/commons/d/d4/Lambang_Kabupaten_Malaka.png" alt="Logo Kabupaten Malaka">
                <span>SILAKIP</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav align-items-center gap-2">
                    <li class="nav-item"><a class="nav-link" href="#hero">Beranda</a></li>
                    <li class="nav-item"><a class="nav-link" href="#keunggulan">Keunggulan</a></li>
                    <li class="nav-item ms-lg-3">
                        <a href="#upload" class="btn btn-primary btn-pill shadow-sm">Mulai Upload Dokumen <i class="bi bi-arrow-right"></i></a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <section id="hero" class="hero-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-xl-6 col-lg-7">
                    <div class="hero-badge">Platform Akuntabilitas E-Government</div>
                    <h1 class="hero-title">
                        <span>SILAKIP</span>
                        <span class="hero-sub-text">(Sistem Informasi Layanan Data Akuntabilitas Kinerja Instansi Pemerintah)</span>
                    </h1>
                    <p class="hero-subtitle">Mekanisme koordinasi terintegrasi dan pengelolaan arsip data pendukung LAKIP secara efisien, terstandar, serta real-time.</p>
                    
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="#upload" class="btn btn-primary btn-pill">Upload Data LAKIP <i class="bi bi-cloud-arrow-up"></i></a>
                        <a href="#keunggulan" class="btn btn-outline-secondary btn-pill">Pelajari Ekosistem</a>
                    </div>
                </div>
                
                <div class="col-xl-6 col-lg-5">
                    <div class="dashboard-window">
                        <div class="floating-pane pane-progress">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold small">Total Kepatuhan</span>
                                <span class="badge bg-success-subtle text-success">96%</span>
                            </div>
                            <svg width="100" height="100" class="d-block mx-auto mt-2">
                                <circle cx="50" cy="50" r="40" stroke="#E2E8F0" stroke-width="8" fill="transparent"/>
                                <circle class="progress-ring-circle" cx="50" cy="50" r="40" stroke="var(--primary)" stroke-width="8" fill="transparent"/>
                            </svg>
                        </div>

                        <div class="floating-pane pane-chart">
                            <h6 class="fw-bold small mb-3">Statistik Pengiriman</h6>
                            <div class="mb-2">
                                <div class="d-flex justify-content-between small text-muted mb-1" style="font-size:11px;">
                                    <span>Renstra Berkas</span><span>88%</span>
                                </div>
                                <div class="mini-bar"><div class="mini-bar-fill" style="width: 88%;"></div></div>
                            </div>
                            <div>
                                <div class="d-flex justify-content-between small text-muted mb-1" style="font-size:11px;">
                                    <span>LKjIP Utama</span><span>94%</span>
                                </div>
                                <div class="mini-bar"><div class="mini-bar-fill" style="width: 94%; background:var(--accent);"></div></div>
                            </div>
                        </div>

                        <div class="floating-pane pane-activity">
                            <h6 class="fw-bold small mb-2"><i class="bi bi-clock-history text-secondary me-2"></i>Aktivitas Terkini</h6>
                            <div class="d-flex gap-2 align-items-center py-1 border-bottom border-light">
                                <div class="badge bg-light text-dark p-2 rounded"><i class="bi bi-file-earmark-code"></i></div>
                                <div class="overflow-hidden"><p class="mb-0 small fw-bold text-truncate">Dinas Kesehatan.pdf</p><span class="text-muted" style="font-size:10px;">Baru Saja</span></div>
                            </div>
                            <div class="d-flex gap-2 align-items-center pt-2">
                                <div class="badge bg-light text-dark p-2 rounded"><i class="bi bi-file-earmark-code"></i></div>
                                <div class="overflow-hidden"><p class="mb-0 small fw-bold text-truncate">Dinas Pertanian.xlsx</p><span class="text-muted" style="font-size:10px;">2 Menit Lalu</span></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="stats-section">
        <div class="container">
            <div class="stat-card-wrapper">
                <div class="stat-premium-card large-stat">
                    <div>
                        <div class="stat-number">39</div>
                        <h5 class="fw-bold">Instansi / OPD</h5>
                    </div>
                    <p class="mb-0 text-white-50 small mt-3">Seluruh Organisasi Perangkat Daerah terintegrasi penuh.</p>
                </div>
                
                <div class="stat-premium-card mid-stat">
                    <div>
                        <div class="stat-number" style="color:var(--primary)">145</div>
                        <h5 class="fw-bold text-secondary">Dokumen Sah</h5>
                    </div>
                    <p class="mb-0 text-muted small mt-3">Arsip data pendukung tervalidasi sistem.</p>
                </div>

                <div class="stat-premium-card tall-stat">
                    <div>
                        <div class="stat-number" style="color:var(--accent)">96%</div>
